<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center_horizontal" android:padding="16dp">
    <TextView android:id="@+id/total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/ 0.00" android:textSize="40sp" android:textStyle="bold" android:layout_marginTop="32dp"/>
    <TextView android:text="Total recibido" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/contador" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Historial - 0 monedas" android:textStyle="bold" android:layout_marginTop="16dp"/>
    <ListView android:id="@+id/lista" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="8dp"/>
</LinearLayout>
